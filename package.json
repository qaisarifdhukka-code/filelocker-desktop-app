{
  "name": "vaultlocker",
  "private": true,
  "version": "1.0.0",
  "description": "USB Vault Encryption Tool",
  "author": "VaultLocker",
  "main": "main.js",
  "scripts": {
    "dev:react": "vite --port 5173 --strictPort",
    "dev:electron": "cross-env NODE_ENV=development VITE_DEV_PORT=5173 electron .",
    "dev": "concurrently -k \"npm run dev:react\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "build": "vite build",
    "prebuild-unlock": "cd ../unlock-app && npm run build",
    "dist": "npm run prebuild-unlock && npm run build && node -e \"require('fs').copyFileSync('../unlock-app/dist/index.html', './Unlock_Vault.html')\" && electron-builder",
    "lint": "eslint ."
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "hash-wasm": "^4.12.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.vaultlocker.app",
    "productName": "VaultLocker",
    "compression": "store",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "Unlock_Vault.html"
    ],
    "win": {
      "target": "dir"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
